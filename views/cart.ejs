<!DOCTYPE html>
<html>
<head>
    <title>Cart</title>
</head>
<body>
    <h1>Shopping Cart</h1>

    <% if(cartItems.length === 0){ %>
        <p>Cart is empty</p>
    <% } else { %>
        <% cartItems.forEach(item => { %>
            <div style="border:1px solid black; padding:10px; margin:10px;">
                <h2><%= item.name %></h2>
                <p>Price: ₹<%= item.price %></p>
            </div>
        <% }) %>
    <% } %>

    <a href="/">Back to Products</a>
</body>
</html>
